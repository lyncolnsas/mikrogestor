# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

/src/generated/prisma

# Custom logs and texts
*.log
*.txt
*.sql
!create_missing_tables.sql
!create_financial_config.sql
!move_to_management.sql
!servers_dump.sql

# Secrets and Keys
config/wireguard/*.key
config/wireguard/*.conf
temp_keys.json
temp_keys_utf8.json

# Local Databases Content (Postgres, Redis)
data/
