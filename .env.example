# ============================================================================
# MIKROGESTOR - Configuração de Ambiente (Exemplo)
# ============================================================================

# -----------------------------------------------------------------------------
# DATABASE (PostgreSQL)
# -----------------------------------------------------------------------------
DB_USER=postgres
DB_PASSWORD=your_secure_password
DB_NAME=mikrogestor

# Database URL completa
DATABASE_URL=postgresql://postgres:password@localhost:5432/mikrogestor?search_path=management,tenant_template,radius

# -----------------------------------------------------------------------------
# NEXTAUTH (Autenticação)
# -----------------------------------------------------------------------------
# Generate one with: openssl rand -base64 32
NEXTAUTH_SECRET=your_nextauth_secret_here
NEXTAUTH_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000
APP_SECRET=your_vpn_encryption_secret_key

# -----------------------------------------------------------------------------
# REDIS (Cache/Queue)
# -----------------------------------------------------------------------------
REDIS_HOST=localhost
REDIS_PORT=6379

# -----------------------------------------------------------------------------
# VPN (WireGuard)
# -----------------------------------------------------------------------------
VPN_HOST=auto
VPN_AUTO_REGISTER=true
VPN_SERVER_ID=default-server
VPN_SERVER_SECRET=your_internal_server_secret

# -----------------------------------------------------------------------------
# PAYMENT GATEWAY (Asaas)
# -----------------------------------------------------------------------------
ASAAS_MASTER_API_KEY=your_asaas_api_key_here
ASAAS_MASTER_WEBHOOK_TOKEN=your_webhook_token_here

# -----------------------------------------------------------------------------
# LOGS
# -----------------------------------------------------------------------------
LOG_LEVEL=info
NODE_ENV=development
